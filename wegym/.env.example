# Database
DATABASE_URL="postgresql://user:password@localhost:5432/wegym?schema=public"

# NextAuth (generate with: openssl rand -hex 32)
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# Mercado Pago
MP_ACCESS_TOKEN="your-mp-access-token"
NEXT_PUBLIC_MP_PUBLIC_KEY="your-mp-public-key"

# Resend (email)
RESEND_API_KEY="your-resend-api-key"

# Node environment
NODE_ENV="production"

# PostgreSQL password (Docker Compose)
POSTGRES_PASSWORD="your-strong-password"
REDIS_PASSWORD="your-redis-password"

# Sentry (error tracking)
# Generate via: bash scripts/setup-sentry.sh
SENTRY_DSN="https://key@oXXX.ingest.us.sentry.io/XXXXXX"
NEXT_PUBLIC_SENTRY_DSN="https://key@oXXX.ingest.us.sentry.io/XXXXXX"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="wegym"
SENTRY_AUTH_TOKEN="your-auth-token"

# Redis (cache & rate limiting)
REDIS_URL="redis://:password@redis:6379"

# CDN (optional - for static assets)
NEXT_PUBLIC_CDN_URL="https://cdn.wegym.app"
