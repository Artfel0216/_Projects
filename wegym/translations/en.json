  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last updated: June 2026",
    "section1Title": "1. Introduction",
    "section1Body": "WEGYM respects your privacy. This policy describes how we collect, use, store and protect your personal data in compliance with the Brazilian General Data Protection Law (LGPD - Law No. 13.709/2018).",
    "section2Title": "2. Data Collected",
    "section2Body": "We collect the following personal data voluntarily provided by you:",
    "section2List1": "Full name, CPF, email, date of birth, gender, address (ZIP code, city, state)",
    "section2List2": "Physical data: weight, height, age, experience level, injuries, health conditions, medications",
    "section2List3": "Usage data: training sessions, modalities practiced, performance, heart rate, calories",
    "section2List4": "For Personal Trainers: CREF number, professional registration",
    "section2List5": "Payment data processed exclusively by Mercado Pago (we do not store card data)",
    "section3Title": "3. Purpose of Processing",
    "section3Body": "Your data is used to:",
    "section3List1": "Create and manage your WEGYM account",
    "section3List2": "Personalize workout plans based on your profile and goals",
    "section3List3": "Generate performance and evolution statistics",
    "section3List4": "Process premium plan payments (via Mercado Pago)",
    "section3List5": "Send platform communications (with your consent)",
    "section3List6": "Comply with legal and regulatory obligations",
    "section4Title": "4. Data Sharing",
    "section4Body": "We share your data only with: Mercado Pago (payment processing), infrastructure service providers (hosting, database, CDN). We do not sell your personal data to third parties.",
    "section5Title": "5. Storage and Security",
    "section5Body": "Your data is stored on secure servers with encryption at rest and in transit (TLS 1.3). We implement strict access controls and continuous monitoring to protect your information against unauthorized access.",
    "section6Title": "6. Your Rights (LGPD)",
    "section6Body": "You have the right to: confirm the existence of data processing; access your data; correct incomplete or outdated data; anonymize or delete unnecessary data; request data portability to another provider; revoke consent at any time.",
    "section7Title": "7. Cookies",
    "section7Body": "We use essential cookies for platform operation (authentication, session, preferences). We do not use tracking or advertising cookies without your explicit consent.",
    "section8Title": "8. Account Deletion",
    "section8Body": "You can request the deletion of your account at any time in the profile settings. After deletion, your personal data will be anonymized within 30 days. Data required for legal obligations (such as payment records) will be retained as required by law.",
    "section9Title": "9. Contact",
    "section9Body": "To exercise your rights, clarify doubts or report incidents, contact us at: privacidade@wegym.com.br or through the privacy section in the app.",
    "section10Title": "10. Changes to this Policy",
    "section10Body": "This policy may be updated periodically. We will notify you of significant changes by email or in the app. We recommend reviewing this page regularly."
  },
